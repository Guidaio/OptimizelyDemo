# Credenciais locais — copiar para local.env e preencher (NAO versionar local.env)
# cp secrets/local.env.example secrets/local.env

# Admin CMS (criado em /Util/Register no primeiro run)
OPTIMIZELY_ADMIN_USERNAME=admin
OPTIMIZELY_ADMIN_EMAIL=seu-email@exemplo.local
OPTIMIZELY_ADMIN_PASSWORD=

# URLs de desenvolvimento
OPTIMIZELY_SITE_URL=http://localhost:5001
OPTIMIZELY_ADMIN_URL=http://localhost:5001/Optimizely/CMS
