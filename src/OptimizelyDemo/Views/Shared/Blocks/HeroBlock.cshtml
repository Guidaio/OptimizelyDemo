@model HeroBlock
@{
    Layout = null;
}
<section class="hero">
    @if (!ContentReference.IsNullOrEmpty(Model.Image))
    {
        <div class="hero__media">
            @Html.PropertyFor(m => m.Image)
        </div>
    }
    <div class="hero__content">
        @if (!string.IsNullOrWhiteSpace(Model.Title))
        {
            <h2 class="hero__title">@Html.PropertyFor(m => m.Title)</h2>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
        {
            <p class="hero__subtitle">@Html.PropertyFor(m => m.Subtitle)</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.CtaText) && Model.CtaLink is not null && !Model.CtaLink.IsEmpty())
        {
            <a class="hero__cta" href="@Model.CtaLink">@Model.CtaText</a>
        }
    </div>
</section>
